<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>TRON IPTV</title>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<style>
/*==== RESET ====*/
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;background:#08121c;color:#c8e0f0;font-family:'Segoe UI',system-ui,sans-serif;font-size:13px}

/*==== VARS ====*/
:root{
  --bg:#08121c;
  --bg2:#0c1926;
  --bg3:#0f2030;
  --bg4:#07111b;
  --act:#b71c1c;
  --c:#00c8ff;
  --bdr:#182f45;
  --bdr2:#1c3d58;
  --td:#3a6678;
  --tdm:#1d3448;
  --acc:#ff3a50;
  --gold:#ffc030;
  --grn:#00cc60;
  --H:52px;
  --N:42px;
}

/*==== TOPBAR ====*/
#bar{
  position:fixed;inset:0 0 auto 0;height:var(--H);z-index:600;
  display:flex;align-items:center;padding:0 14px;gap:10px;
  background:var(--bg2);border-bottom:2px solid var(--act);
}
.logo{display:flex;align-items:center;gap:8px;cursor:pointer;flex-shrink:0;user-select:none}
.logo-t{font-size:18px;font-weight:900;letter-spacing:2px;color:var(--c)}
.logo-t b{color:var(--td);font-weight:300}
#mbadge{padding:2px 10px;background:var(--act);color:#fff;font-size:10px;font-weight:800;letter-spacing:2px;flex-shrink:0;border-radius:2px}
#clk{flex:1;text-align:center;font-size:13px;color:#5a8ca8;letter-spacing:1px}
.ibtn{background:none;border:none;color:var(--td);cursor:pointer;padding:7px;display:flex;align-items:center;border-radius:4px;transition:.15s}
.ibtn:hover{color:var(--c);background:rgba(0,200,255,.1)}
.ibtn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}

/*==== NAV TABS ====*/
#nav{
  position:fixed;top:var(--H);inset-inline:0;height:var(--N);z-index:599;
  display:flex;align-items:center;padding:0 10px;
  background:var(--bg3);border-bottom:1px solid var(--bdr);
}
.ntab{
  padding:8px 18px;background:none;border:none;
  border-bottom:3px solid transparent;margin-bottom:-1px;
  color:var(--td);font-size:13px;font-weight:700;letter-spacing:1px;
  cursor:pointer;transition:.15s;white-space:nowrap;
}
.ntab:hover{color:#d0e8f5}
.ntab.on{color:var(--c);border-bottom-color:var(--c)}

/*==== WORKSPACE ====*/
#ws{
  position:fixed;
  top:calc(var(--H) + var(--N));
  inset-inline:0;bottom:0;
  overflow:hidden;
}

/* ─────────────────────────────────
   PAINEL PRINCIPAL — 3 colunas
   col-A: categorias
   col-B: itens da categoria
   col-C: card de info / player
───────────────────────────────── */
#main{
  position:absolute;inset:0;
  display:grid;
  /* padrão: 3 cols */
  grid-template-columns:240px 1fr 0px;
  grid-template-rows:100%;
  transition:grid-template-columns .25s;
}

/* estado sem cat selecionada: col-B oculta, col-C oculta */
#main.s-cats{
  grid-template-columns:240px 1fr 0px;
}
/* estado com cat + sem item: col-C oculta */
#main.s-items{
  grid-template-columns:240px 1fr 0px;
}
/* estado com item selecionado: col-C visível */
#main.s-card{
  grid-template-columns:240px 1fr 280px;
}
/* player aberto: ocupa tudo */
#main.s-play{
  grid-template-columns:260px 1fr 240px;
}

/*=== COL A — categorias ===*/
#col-a{
  display:flex;flex-direction:column;
  background:var(--bg2);border-right:1px solid var(--bdr2);
  overflow:hidden;height:100%;
}
#ca-head{
  padding:10px 14px;font-size:10px;font-weight:800;letter-spacing:3px;
  color:var(--c);background:var(--bg3);border-bottom:1px solid var(--bdr);
  flex-shrink:0;
}
#ca-srch{padding:7px 10px;background:var(--bg2);border-bottom:1px solid var(--bdr);flex-shrink:0}
#ca-srch input{
  width:100%;background:var(--bg4);border:1px solid var(--bdr);
  color:#d0e8f5;padding:6px 10px;font-size:12px;outline:none;
}
#ca-srch input:focus{border-color:var(--c)}
#ca-srch input::placeholder{color:var(--tdm)}
#ca-list{flex:1;overflow-y:auto}
#ca-list::-webkit-scrollbar{width:4px}
#ca-list::-webkit-scrollbar-thumb{background:var(--bdr)}

.cat-item{
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  padding:11px 14px;cursor:pointer;
  border-bottom:1px solid rgba(24,47,69,.8);
  border-left:3px solid transparent;
  transition:.1s;
}
.cat-item:hover{background:rgba(12,45,68,.5)}
.cat-item.on{background:var(--act);border-left-color:#ff7070}
.cat-item-n{font-size:13px;font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cat-item-c{font-size:11px;color:var(--td);flex-shrink:0;font-weight:700}
.cat-item.on .cat-item-n,.cat-item.on .cat-item-c{color:#fff}

/*=== COL B — grade de itens ===*/
#col-b{
  display:flex;flex-direction:column;
  background:var(--bg);overflow:hidden;height:100%;
}
#cb-head{
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  padding:9px 14px;
  background:var(--bg3);border-bottom:1px solid var(--bdr);
  flex-shrink:0;
}
#cb-title{font-size:15px;font-weight:900;letter-spacing:2px;color:#fff}
#cb-srch{
  background:var(--bg4);border:1px solid var(--bdr);color:#d0e8f5;
  padding:6px 12px;font-size:12px;outline:none;width:200px;flex-shrink:0;
}
#cb-srch:focus{border-color:var(--c)}
#cb-srch::placeholder{color:var(--tdm)}
#cb-msg{padding:8px 14px;font-size:11px;color:var(--td);letter-spacing:2px;flex-shrink:0;background:var(--bg3)}

/* GRADE DE CARDS — estilo do screenshot */
#cb-grid{
  flex:1;overflow-y:auto;
  padding:12px;
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(130px,1fr));
  gap:10px;
  align-content:start;
}
#cb-grid::-webkit-scrollbar{width:5px}
#cb-grid::-webkit-scrollbar-thumb{background:var(--bdr)}

.icard{
  cursor:pointer;background:var(--bg3);
  border:2px solid transparent;border-radius:4px;
  overflow:hidden;display:flex;flex-direction:column;
  transition:border-color .15s,transform .15s,box-shadow .15s;
}
.icard:hover{border-color:var(--c);transform:scale(1.04);box-shadow:0 0 18px rgba(0,200,255,.2)}
.icard.on{border-color:var(--c);box-shadow:0 0 22px rgba(0,200,255,.35)}

.icard-img{
  width:100%;aspect-ratio:1/1;
  background:var(--bg4);overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.icard-img img{
  width:100%;height:100%;
  object-fit:contain;padding:8px;display:block;
}
.icard-noimg{font-size:36px;opacity:.2}
/* badge verde no topo do card */
.icard-badge{
  position:absolute;top:0;left:0;right:0;
  padding:3px 5px;
  background:#1a7a3a;
  color:#fff;font-size:9px;font-weight:900;letter-spacing:1px;
  text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
/* dot ao vivo */
.icard-live{
  position:absolute;bottom:5px;right:5px;
  width:8px;height:8px;border-radius:50%;
  background:var(--acc);border:1px solid rgba(255,255,255,.4);
  animation:bl 1.8s infinite;
}
@keyframes bl{0%,100%{opacity:1}50%{opacity:.15}}

.icard-name{
  padding:6px 7px;font-size:11px;font-weight:600;
  text-align:center;line-height:1.3;color:#b8d5e8;
  background:var(--bg3);border-top:1px solid var(--bdr);
}

/*=== COL C — card de info ===*/
#col-c{
  display:flex;flex-direction:column;
  background:var(--bg2);border-left:1px solid var(--bdr2);
  overflow:hidden;height:100%;
  /* oculta via clip quando largura=0 */
}
#cc-inner{
  display:flex;flex-direction:column;gap:0;
  height:100%;overflow-y:auto;
  padding:16px 14px;
  gap:12px;
}
#cc-inner::-webkit-scrollbar{width:3px}
#cc-inner::-webkit-scrollbar-thumb{background:var(--bdr)}

.cc-badge{display:inline-block;padding:3px 10px;background:var(--act);color:#fff;font-size:10px;font-weight:800;letter-spacing:2px;border-radius:2px;align-self:flex-start}
#cc-name{font-size:16px;font-weight:900;line-height:1.3;color:#fff}
#cc-group{font-size:11px;color:var(--c);font-weight:700;letter-spacing:1px}
#cc-thumb{width:100%;aspect-ratio:16/9;background:var(--bg4);overflow:hidden;border-radius:3px;display:none}
#cc-thumb img{width:100%;height:100%;object-fit:cover;display:block}
#cc-desc{font-size:11px;color:var(--td);line-height:1.7}
.cc-divider{height:1px;background:var(--bdr);flex-shrink:0}

/* botão ASSISTIR */
#cc-play-btn{
  margin-top:4px;
  padding:12px;
  background:var(--act);
  border:none;color:#fff;
  font-size:14px;font-weight:800;letter-spacing:2px;
  cursor:pointer;transition:.15s;width:100%;
  display:flex;align-items:center;justify-content:center;gap:8px;
  flex-shrink:0;
}
#cc-play-btn:hover{background:#d32f2f;transform:scale(1.02)}

/* fav btn no card */
#cc-fav-btn{
  padding:9px;background:var(--bg3);border:1px solid var(--bdr);
  color:var(--td);font-size:13px;font-weight:700;
  cursor:pointer;transition:.15s;width:100%;
  display:flex;align-items:center;justify-content:center;gap:6px;
  flex-shrink:0;
}
#cc-fav-btn:hover{border-color:var(--gold);color:var(--gold)}
#cc-fav-btn.on{border-color:var(--gold);color:var(--gold);background:rgba(255,192,48,.07)}

/*=== PLAYER OVERLAY ===*/
/* quando está em modo player, o col-b vira player full */
#player-wrap{
  display:none;
  flex-direction:column;
  flex:1;overflow:hidden;background:var(--bg);
}
#player-wrap.show{display:flex}

#pbox{
  position:relative;background:#000;flex-shrink:0;
  width:100%;aspect-ratio:16/9;max-height:56vh;
}
#pbox video{width:100%;height:100%;display:block}
#pidl{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;
  background:var(--bg2);
}
.pidl-row{display:flex;align-items:center;gap:8px}
.pidl-txt{font-size:20px;font-weight:900;letter-spacing:3px;color:var(--c)}
.pidl-txt b{color:var(--td);font-weight:300}
#pidl p{font-size:10px;letter-spacing:3px;color:var(--tdm)}

/* qbar */
#qbar{display:flex;align-items:center;gap:5px;padding:6px 12px;flex-shrink:0;background:var(--bg2);border-top:1px solid var(--bdr)}
.ql{font-size:9px;font-weight:800;letter-spacing:2px;color:var(--td);flex-shrink:0}
.qb{padding:3px 10px;background:var(--bg4);border:1px solid var(--bdr);color:var(--td);font-size:10px;font-weight:800;cursor:pointer;transition:.12s}
.qb:hover{border-color:var(--c);color:var(--c)}
.qb.on{background:#0a5a78;border-color:var(--c);color:#fff}
#qfs{margin-left:auto;padding:3px 10px;background:none;border:1px solid var(--c);color:var(--c);font-size:10px;font-weight:800;cursor:pointer;transition:.12s}
#qfs:hover{background:var(--c);color:#000}

/* painel lista no player — col-a vira lista de itens */
#play-list{flex:1;overflow-y:auto;display:none}
#play-list.show{display:block}
#play-list::-webkit-scrollbar{width:4px}
#play-list::-webkit-scrollbar-thumb{background:var(--bdr)}

/* item compacto na sidebar do player */
.pl-item{
  display:flex;align-items:center;gap:8px;
  padding:8px 10px;cursor:pointer;
  border-bottom:1px solid rgba(24,47,69,.6);
  border-left:3px solid transparent;transition:.1s;
}
.pl-item:hover{background:rgba(12,45,68,.5)}
.pl-item.on{background:var(--act);border-left-color:#ff8080}
.pl-logo{width:42px;height:28px;flex-shrink:0;background:var(--bg4);border-radius:2px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:15px}
.pl-logo img{width:100%;height:100%;object-fit:contain}
.pl-name{flex:1;font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#c0d8e8}
.pl-item.on .pl-name{color:#fff}

/* episódios */
#epp{flex-shrink:0;max-height:180px;background:var(--bg2);border-top:1px solid var(--bdr);display:none;flex-direction:column}
#eph{display:flex;align-items:center;justify-content:space-between;padding:7px 12px;border-bottom:1px solid var(--bdr);flex-shrink:0}
#ept{font-size:12px;font-weight:700;color:var(--c);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#epc{background:none;border:1px solid var(--bdr);color:var(--td);padding:2px 8px;cursor:pointer;font-size:11px;flex-shrink:0;margin-left:8px}
#epc:hover{border-color:var(--acc);color:var(--acc)}
#epss{display:flex;gap:4px;padding:5px 10px;overflow-x:auto;flex-shrink:0;border-bottom:1px solid var(--bdr)}
#epss::-webkit-scrollbar{display:none}
.sea{padding:3px 10px;background:none;border:1px solid var(--bdr);color:var(--td);font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;transition:.12s}
.sea.on{border-color:var(--c);color:var(--c);background:rgba(0,200,255,.07)}
#eprl{flex:1;overflow-y:auto}
#eprl::-webkit-scrollbar{width:3px}
#eprl::-webkit-scrollbar-thumb{background:var(--bdr)}
.epr{display:flex;align-items:center;gap:8px;padding:6px 12px;border-bottom:1px solid rgba(24,47,69,.4);cursor:pointer;transition:.1s}
.epr:hover{background:rgba(12,45,68,.5)}
.epr.on{background:var(--act);border-left:2px solid #ff8080}
.epn{font-size:10px;color:var(--td);width:24px;flex-shrink:0}
.epnm{font-size:12px;font-weight:600;flex:1}
.epd{font-size:10px;color:var(--td)}

/*=== ESTADOS ===*/
.stb{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:50px 20px;color:var(--td);text-align:center;grid-column:1/-1}
.stb p{font-size:11px;letter-spacing:2px}
.spin{width:28px;height:28px;border:2px solid var(--bdr);border-top-color:var(--c);border-radius:50%;animation:sp .7s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}

/*=== TOAST ===*/
#toast{position:fixed;bottom:16px;right:16px;z-index:9999;pointer-events:none;background:var(--bg3);border-left:3px solid var(--c);color:#d0e8f5;padding:9px 16px;font-size:12px;letter-spacing:.5px;transform:translateY(50px);opacity:0;transition:.25s}
#toast.show{transform:none;opacity:1}
#toast.err{border-color:var(--acc);color:var(--acc)}
#toast.ok{border-color:var(--grn);color:var(--grn)}

/*=== MOBILE ===*/
@media(max-width:768px){
  html,body{overflow:auto;height:auto}
  #ws{position:static;overflow:visible;height:auto}
  #main{position:static;display:flex;flex-direction:column;grid-template-columns:none !important}
  #col-a{max-height:220px;border-right:none;border-bottom:1px solid var(--bdr2)}
  #col-c{border-left:none;border-top:1px solid var(--bdr2);min-height:200px}
  #pbox{max-height:none}
  #clk{display:none}
  #cb-grid{grid-template-columns:repeat(auto-fill,minmax(100px,1fr))}
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div id="bar">
  <div class="logo" onclick="resetView()">
    <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
      <polygon points="13,2 24,7.5 24,18.5 13,24 2,18.5 2,7.5" fill="none" stroke="#00c8ff" stroke-width="1.5"/>
      <polygon points="13,6 20,10 20,16 13,20 6,16 6,10" fill="rgba(0,200,255,.1)" stroke="#00c8ff" stroke-width="1"/>
      <text x="13" y="17" text-anchor="middle" fill="#00c8ff" font-size="7" font-weight="bold" font-family="Arial">TV</text>
    </svg>
    <span class="logo-t">TRON<b>IPTV</b></span>
  </div>
  <div id="mbadge">AO VIVO</div>
  <div id="clk"></div>
  <button class="ibtn" onclick="sair()">
    <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
  </button>
</div>

<!-- NAV -->
<nav id="nav">
  <button class="ntab on" data-s="live"   onclick="goNav('live')">📺 AO VIVO</button>
  <button class="ntab"    data-s="movies" onclick="goNav('movies')">🎬 FILMES</button>
  <button class="ntab"    data-s="series" onclick="goNav('series')">📂 SÉRIES</button>
  <button class="ntab"    data-s="favs"   onclick="goNav('favs')">⭐ FAVORITOS</button>
</nav>

<!-- WORKSPACE -->
<div id="ws">
  <div id="main" class="s-cats">

    <!-- COL A: categorias -->
    <div id="col-a">
      <div id="ca-head">CATEGORIAS</div>
      <div id="ca-srch"><input id="ca-inp" type="text" placeholder="🔍 Pesquisar categorias..." oninput="filterCats(this.value)"></div>
      <div id="ca-list"><div class="stb"><div class="spin"></div><p>CARREGANDO...</p></div></div>
    </div>

    <!-- COL B: grade de itens (ou player) -->
    <div id="col-b">
      <!-- header da col-b -->
      <div id="cb-head">
        <span id="cb-title">—</span>
        <input id="cb-srch" type="text" placeholder="🔍 Buscar..." oninput="filterGrid(this.value)">
      </div>
      <div id="cb-msg">← Selecione uma categoria</div>

      <!-- grade de cards -->
      <div id="cb-grid" style="display:none"></div>

      <!-- player (substitui a grade quando assistindo) -->
      <div id="player-wrap">
        <div id="pbox">
          <video id="vid" controls autoplay playsinline></video>
          <div id="pidl">
            <div class="pidl-row">
              <svg width="32" height="32" viewBox="0 0 26 26" fill="none">
                <polygon points="13,2 24,7.5 24,18.5 13,24 2,18.5 2,7.5" fill="none" stroke="#00c8ff" stroke-width="1.5"/>
                <polygon points="13,6 20,10 20,16 13,20 6,16 6,10" fill="rgba(0,200,255,.1)" stroke="#00c8ff" stroke-width="1"/>
                <text x="13" y="17" text-anchor="middle" fill="#00c8ff" font-size="7" font-weight="bold" font-family="Arial">TV</text>
              </svg>
              <span class="pidl-txt">TRON<b>IPTV</b></span>
            </div>
            <p>SELECIONE UM ITEM</p>
          </div>
        </div>
        <div id="qbar">
          <span class="ql">QUALIDADE</span>
          <button class="qb on" onclick="setQ('auto',this)">AUTO</button>
          <button class="qb" onclick="setQ('sd',this)">SD</button>
          <button class="qb" onclick="setQ('hd',this)">HD</button>
          <button class="qb" onclick="setQ('fhd',this)">FULL HD</button>
          <button id="qfs" onclick="goFull()">⛶ TELA CHEIA</button>
        </div>
        <div id="epp">
          <div id="eph"><span id="ept"></span><button id="epc" onclick="closeEp()">✕ Fechar</button></div>
          <div id="epss"></div>
          <div id="eprl"></div>
        </div>
      </div>
    </div>

    <!-- COL C: card info -->
    <div id="col-c">
      <div id="cc-inner">
        <div id="cc-msg" style="color:var(--tdm);font-size:11px;letter-spacing:2px;text-align:center;margin-top:20px">← Selecione um item</div>
        <div id="cc-content" style="display:none;flex-direction:column;gap:12px">
          <div class="cc-badge" id="cc-badge">AO VIVO</div>
          <div id="cc-name"></div>
          <div id="cc-group"></div>
          <div class="cc-divider"></div>
          <div id="cc-thumb"></div>
          <div id="cc-desc"></div>
          <button id="cc-play-btn" onclick="assistir()">▶ &nbsp;ASSISTIR</button>
          <button id="cc-fav-btn" onclick="toggleFavCC()">⭐ &nbsp;FAVORITAR</button>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /ws -->

<div id="toast"></div>

<script>
'use strict';

/* ─── SESSÃO ─── */
const SS=(()=>{try{return JSON.parse(localStorage.getItem('tron_s')||'null')||JSON.parse(sessionStorage.getItem('tron_s')||'null');}catch{return null;}})();
if(!SS?.sv) location.replace('index.html');
const {sv,us,pw}=SS;

/* ─── PROXIES ─── */
const PX=[
  u=>u,
  u=>`https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
  u=>`https://corsproxy.io/?url=${encodeURIComponent(u)}`,
  u=>`https://api.cors.lol/?url=${encodeURIComponent(u)}`,
];
let bpx=0;
async function api(action,extra=''){
  const raw=`${sv}/player_api.php?username=${us}&password=${pw}&action=${action}${extra}`;
  const ord=[bpx,...[0,1,2,3].filter(i=>i!==bpx)];
  for(const i of ord){
    try{
      const r=await fetch(PX[i](raw),{signal:AbortSignal.timeout(14000)});
      if(!r.ok)continue;
      const t=await r.text();
      if(!t?.trim())continue;
      const d=JSON.parse(t);
      bpx=i;return d;
    }catch(e){console.warn('px'+i,e.message);}
  }
  throw new Error('Servidor inacessível. Verifique URL e credenciais.');
}

/* ─── ESTADO ─── */
let sec='live';
let cats=[],streams=[],vcats=[];
let activeCatIdx=-1, activeCatItems=[], activeCatName='';
let activeItem=null;
let playItem=null, curl=null;
let HLS=null, rtr=0, qm='auto';
let playMode=false; // true quando o player está visível

/* ─── INIT ─── */
addEventListener('DOMContentLoaded',()=>{
  const cl=document.getElementById('clk');
  (function tk(){
    const n=new Date();
    cl.textContent=n.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})+' · '+n.toLocaleDateString('pt-BR',{day:'2-digit',month:'short'});
    setTimeout(tk,1000);
  })();
  goNav('live');
});

/* ─── TOAST ─── */
function toast(m,c=''){const el=document.getElementById('toast');el.textContent=m;el.className='toast show '+c;clearTimeout(el._t);el._t=setTimeout(()=>el.className='toast',3000);}

/* ─── FAVS ─── */
const gF=()=>{try{return JSON.parse(localStorage.getItem('tf')||'[]');}catch{return[];}};
const sF=a=>localStorage.setItem('tf',JSON.stringify(a));
const isF=id=>gF().some(z=>z._id===id);
function togF(item){
  let f=gF(),i=f.findIndex(z=>z._id===item._id);
  if(i>=0){f.splice(i,1);sF(f);toast('Removido dos favoritos','err');return false;}
  f.push(item);sF(f);toast('⭐ Adicionado!','ok');return true;
}
function toggleFavCC(){
  if(!activeItem)return;
  const on=togF(activeItem);
  const btn=document.getElementById('cc-fav-btn');
  btn.classList.toggle('on',on);
  btn.textContent=on?'⭐  FAVORITADO':'⭐  FAVORITAR';
  if(sec==='favs') loadFavs();
}

/* ─── NAV ─── */
function goNav(s){
  sec=s;
  document.querySelectorAll('.ntab').forEach(b=>b.classList.toggle('on',b.dataset.s===s));
  document.getElementById('mbadge').textContent={live:'AO VIVO',movies:'FILMES',series:'SÉRIES',favs:'FAVORITOS'}[s];
  closeEp();
  stopPlayer();
  resetView();
  s==='favs'?loadFavs():loadSec(s);
}

/* ─── RESET VIEW ─── */
function resetView(){
  setMainState('s-cats');
  document.getElementById('cb-msg').style.display='';
  document.getElementById('cb-grid').style.display='none';
  hidePlayer();
  hideCCContent();
  document.querySelectorAll('.cat-item').forEach(x=>x.classList.remove('on'));
  activeCatIdx=-1; activeCatItems=[]; activeCatName='';
  activeItem=null; playItem=null;
}

function setMainState(cls){
  const m=document.getElementById('main');
  m.className=cls;
}

/* ─── LOAD SEÇÃO ─── */
async function loadSec(s){
  document.getElementById('ca-list').innerHTML='<div class="stb"><div class="spin"></div><p>CARREGANDO...</p></div>';
  document.getElementById('cb-title').textContent='—';
  document.getElementById('cb-msg').style.display='';
  document.getElementById('cb-grid').style.display='none';
  try{
    const m={
      live:  ['get_live_categories','get_live_streams'],
      movies:['get_vod_categories',   'get_vod_streams'],
      series:['get_series_categories','get_series'],
    };
    const [ca,sa]=m[s];
    const [cr,sr]=await Promise.all([api(ca),api(sa)]);
    cats=Array.isArray(cr)?cr:[];
    streams=mkStreams(sr,s);
    vcats=cats.filter(c=>streams.some(st=>st.cat===String(c.category_id)));
    renderCatList(vcats,-1);
    toast(`✅ ${streams.length} itens`,'ok');
  }catch(e){
    document.getElementById('ca-list').innerHTML=`<div class="stb"><p>⚠️ ${x(e.message)}</p></div>`;
    toast(e.message,'err');
  }
}

/* ─── BUILD STREAMS ─── */
function mkStreams(raw,s){
  if(!Array.isArray(raw))return[];
  if(s==='live') return raw.map((c,i)=>({
    _id:'l_'+c.stream_id,num:i+1,type:'live',
    name:c.name||'—',
    url:`${sv}/live/${us}/${pw}/${c.stream_id}.m3u8`,
    img:c.stream_icon||'',cat:String(c.category_id||''),grp:c.category_name||'',
  }));
  if(s==='movies') return raw.map((m,i)=>({
    _id:'m_'+m.stream_id,num:i+1,type:'movie',
    name:m.name||'—',
    url:`${sv}/movie/${us}/${pw}/${m.stream_id}.${m.container_extension||'mp4'}`,
    urlAlt:`${sv}/movie/${us}/${pw}/${m.stream_id}.m3u8`,
    img:m.stream_icon||'',cat:String(m.category_id||''),grp:m.category_name||'',
  }));
  return raw.map((z,i)=>({
    _id:'sr_'+z.series_id,num:i+1,type:'series',
    name:z.name||'—',url:null,
    img:z.cover||'',cat:String(z.category_id||''),grp:z.category_name||'',
    sid:z.series_id,
  }));
}

/* ─── RENDERIZA LISTA DE CATEGORIAS (col A) ─── */
function renderCatList(list, selIdx){
  const el=document.getElementById('ca-list');
  el.innerHTML='';
  const f=document.createDocumentFragment();

  // TODOS
  const allItems=streams;
  const dAll=mkCatEl('TODOS', allItems.length, selIdx===-1);
  dAll.onclick=()=>selectCat(-1, allItems, 'TODOS', dAll);
  f.appendChild(dAll);

  list.forEach((c,i)=>{
    const items=streams.filter(s=>s.cat===String(c.category_id));
    if(!items.length)return;
    const d=mkCatEl(c.category_name||'—', items.length, i===selIdx);
    d.onclick=()=>selectCat(i, items, c.category_name||'—', d);
    f.appendChild(d);
  });
  el.appendChild(f);
}

function mkCatEl(name,count,active){
  const d=document.createElement('div');
  d.className='cat-item'+(active?' on':'');
  d.innerHTML=`<span class="cat-item-n">${x(name)}</span><span class="cat-item-c">${count}</span>`;
  return d;
}

function filterCats(q){
  const lq=q.toLowerCase();
  renderCatList(lq?vcats.filter(c=>(c.category_name||'').toLowerCase().includes(lq)):vcats, activeCatIdx);
}

/* ─── SELECIONA CATEGORIA → abre grade na col B ─── */
function selectCat(idx, items, name, el){
  // destaca na sidebar
  document.querySelectorAll('.cat-item').forEach(x=>x.classList.remove('on'));
  el.classList.add('on');

  activeCatIdx=idx;
  activeCatItems=items;
  activeCatName=name;

  // volta do player se estava
  if(playMode) exitPlayer();

  // esconde card info se tinha
  hideCCContent();
  activeItem=null;

  document.getElementById('cb-title').textContent=name;
  document.getElementById('cb-srch').value='';
  document.getElementById('cb-msg').style.display='none';
  document.getElementById('cb-grid').style.display='';
  renderGrid(items);
  setMainState('s-items');
}

/* ─── RENDERIZA GRADE DE CARDS (col B) ─── */
function renderGrid(list){
  const el=document.getElementById('cb-grid');
  el.innerHTML='';
  if(!list.length){el.innerHTML='<div class="stb"><p>🔍 NENHUM ITEM</p></div>';return;}
  const live=sec==='live';
  const f=document.createDocumentFragment();
  list.forEach(item=>{
    const d=document.createElement('div');
    d.className='icard'+(activeItem&&activeItem._id===item._id?' on':'');
    d.dataset.id=item._id;
    const icon=live?'📺':sec==='series'?'📂':'🎬';
    const badge=x(item.grp||sec.toUpperCase());
    d.innerHTML=`
      <div class="icard-img">
        ${item.img?`<img src="${x(item.img)}" loading="lazy" onerror="this.style.display='none'">`:`<span class="icard-noimg">${icon}</span>`}
        <div class="icard-badge">${badge}</div>
        ${live?'<div class="icard-live"></div>':''}
      </div>
      <div class="icard-name">${x(item.name)}</div>`;
    // clique no card → abre col C com info
    d.addEventListener('click',()=>selectItem(item, d));
    f.appendChild(d);
  });
  el.appendChild(f);
}

function filterGrid(q){
  const lq=q.toLowerCase();
  renderGrid(lq?activeCatItems.filter(i=>i.name.toLowerCase().includes(lq)):activeCatItems);
}

/* ─── SELECIONA ITEM → abre card info na col C ─── */
function selectItem(item, cardEl){
  activeItem=item;
  // destaca card
  document.querySelectorAll('.icard').forEach(c=>c.classList.remove('on'));
  if(cardEl) cardEl.classList.add('on');

  // preenche col C
  showCCContent(item);
  setMainState('s-card');
}

function showCCContent(item){
  document.getElementById('cc-msg').style.display='none';
  const cc=document.getElementById('cc-content');
  cc.style.display='flex';

  document.getElementById('cc-badge').textContent=item.type==='live'?'AO VIVO':item.type==='movie'?'FILME':'SÉRIE';
  document.getElementById('cc-name').textContent=item.name;
  document.getElementById('cc-group').textContent=item.grp||'';
  document.getElementById('cc-desc').textContent='';

  const th=document.getElementById('cc-thumb');
  if(item.img&&item.type!=='live'){
    th.style.display='block';
    th.innerHTML=`<img src="${x(item.img)}" style="width:100%;height:100%;object-fit:cover;border-radius:3px" onerror="this.parentElement.style.display='none'">`;
  } else th.style.display='none';

  // fav btn
  const fb=document.getElementById('cc-fav-btn');
  const faved=isF(item._id);
  fb.classList.toggle('on',faved);
  fb.innerHTML=faved?'⭐  FAVORITADO':'⭐  FAVORITAR';
}

function hideCCContent(){
  document.getElementById('cc-msg').style.display='';
  document.getElementById('cc-content').style.display='none';
}

/* ─── ASSISTIR — abre o player ─── */
function assistir(){
  if(!activeItem)return;
  if(activeItem.type==='series'){
    // série: abre ep panel primeiro, player fica aguardando ep
    openSeriesPlayer(activeItem);
    return;
  }
  enterPlayer(activeItem);
}

function enterPlayer(item){
  playItem=item;
  playMode=true;

  // col B: esconde grade, mostra player
  document.getElementById('cb-grid').style.display='none';
  document.getElementById('cb-msg').style.display='none';
  document.getElementById('player-wrap').classList.add('show');
  document.getElementById('pidl').style.display='none';

  // col A: mostra lista compacta de itens da categoria atual
  showPlayList(activeCatItems, item._id);
  setMainState('s-play');

  // atualiza info no col C
  showCCContent(item);

  // toca
  startPlay(item.url, item.name, item.type==='live', item.urlAlt||null);
}

function exitPlayer(){
  stopPlayer();
  playMode=false;
  document.getElementById('player-wrap').classList.remove('show');
  document.getElementById('cb-grid').style.display='';
  document.getElementById('ca-list').querySelectorAll('.pl-item-wrap').forEach(x=>x.remove());
  // restaura cat list normal
  renderCatList(vcats, activeCatIdx);
  closeEp();
}

/* ─── LISTA COMPACTA NO PLAYER (col A) ─── */
function showPlayList(list, activeId){
  // a col-a mantém a lista de cats mas ABAIXO adiciona scroll de items
  // na verdade: substituímos o conteúdo do ca-list por lista de itens
  const el=document.getElementById('ca-list');
  el.innerHTML='';
  // botão voltar para categorias
  const back=document.createElement('div');
  back.style.cssText='padding:10px 14px;cursor:pointer;background:rgba(0,200,255,.07);border-bottom:1px solid var(--bdr);font-size:12px;color:var(--c);font-weight:800;letter-spacing:1px;display:flex;align-items:center;gap:6px';
  back.innerHTML='‹ &nbsp;VOLTAR CATEGORIAS';
  back.onclick=()=>exitPlayer();
  el.appendChild(back);

  // nome da cat
  const hn=document.createElement('div');
  hn.style.cssText='padding:8px 14px;font-size:10px;font-weight:800;letter-spacing:2px;color:var(--td);background:var(--bg3);border-bottom:1px solid var(--bdr)';
  hn.textContent=activeCatName.toUpperCase();
  el.appendChild(hn);

  const f=document.createDocumentFragment();
  list.forEach(item=>{
    const d=document.createElement('div');
    d.className='pl-item'+(item._id===activeId?' on':'');
    d.dataset.id=item._id;
    const icon=sec==='live'?'📺':sec==='series'?'📂':'🎬';
    d.innerHTML=`
      <div class="pl-logo">${item.img?`<img src="${x(item.img)}" loading="lazy" onerror="this.style.display='none'">`:`<span>${icon}</span>`}</div>
      <span class="pl-name">${x(item.name)}</span>`;
    d.addEventListener('click',()=>{
      if(item.type==='series'){openSeriesPlayer(item);return;}
      document.querySelectorAll('.pl-item').forEach(z=>z.classList.remove('on'));
      d.classList.add('on');
      playItem=item;
      showCCContent(item);
      startPlay(item.url,item.name,item.type==='live',item.urlAlt||null);
    });
    f.appendChild(d);
  });
  el.appendChild(f);
}

/* ─── PLAYER ─── */
function stopPlayer(){
  const v=document.getElementById('vid');
  if(HLS){HLS.destroy();HLS=null;}
  v.pause();v.src='';curl=null;rtr=0;
}
function hidePlayer(){
  document.getElementById('player-wrap').classList.remove('show');
  playMode=false;
}

function startPlay(url,name,isLive,alt){
  rtr=0;curl=url;
  const v=document.getElementById('vid');
  if(HLS){HLS.destroy();HLS=null;}

  function hls(u){
    if(HLS){HLS.destroy();HLS=null;}
    HLS=new Hls({enableWorker:true});
    HLS.loadSource(u);HLS.attachMedia(v);
    HLS.on(Hls.Events.MANIFEST_PARSED,(_,d)=>{applyQ(HLS,d.levels);v.play().catch(()=>{});});
    HLS.on(Hls.Events.ERROR,(_,d)=>{
      if(d.fatal&&curl===url){
        rtr++;
        if(rtr<=4){toast(`Reconectando ${rtr}/4…`,'err');setTimeout(()=>hls(u),rtr*2500);}
        else toast('Stream indisponível','err');
      }
    });
  }

  if(isLive){
    if(Hls.isSupported())hls(url);
    else{v.src=url;v.play().catch(()=>{});}
  } else if(url.endsWith('.m3u8')&&Hls.isSupported()){
    hls(url);
  } else {
    v.src=url;v.load();
    v.play().catch(()=>{if(alt&&Hls.isSupported())hls(alt);});
    v.onerror=()=>{if(alt&&Hls.isSupported())hls(alt);else toast('Formato não suportado','err');};
  }
}

function applyQ(h,lvls){
  if(!lvls?.length||qm==='auto'){h.currentLevel=-1;return;}
  const s=[...lvls].map((l,i)=>({i,h:l.height||0})).sort((a,b)=>a.h-b.h);
  if(qm==='sd')h.currentLevel=s[0]?.i??-1;
  else if(qm==='hd')h.currentLevel=(s.find(l=>l.h>=720)||s[Math.floor(s.length/2)])?.i??-1;
  else h.currentLevel=(s.find(l=>l.h>=1080)||s[s.length-1])?.i??-1;
}
function setQ(q,btn){qm=q;document.querySelectorAll('.qb').forEach(b=>b.classList.remove('on'));btn.classList.add('on');if(HLS)applyQ(HLS,HLS.levels);toast('Qualidade: '+q.toUpperCase());}
function goFull(){const v=document.getElementById('vid');(v.requestFullscreen||v.webkitRequestFullscreen||v.mozRequestFullScreen).call(v);}

/* ─── SÉRIES ─── */
async function openSeriesPlayer(item){
  // entra no modo player se ainda não
  if(!playMode){
    playMode=true;
    document.getElementById('cb-grid').style.display='none';
    document.getElementById('cb-msg').style.display='none';
    document.getElementById('player-wrap').classList.add('show');
    showPlayList(activeCatItems, item._id);
    setMainState('s-play');
  }
  document.querySelectorAll('.pl-item').forEach(z=>z.classList.remove('on'));
  document.querySelector(`.pl-item[data-id="${item._id}"]`)?.classList.add('on');
  showCCContent(item);

  document.getElementById('ept').textContent=item.name;
  document.getElementById('epss').innerHTML='<div class="spin" style="margin:6px 14px"></div>';
  document.getElementById('eprl').innerHTML='';
  document.getElementById('epp').style.display='flex';

  try{
    const d=await api('get_series_info','&series_id='+item.sid);
    const ep=d.episodes||{};
    if(d.info?.plot)document.getElementById('cc-desc').textContent=d.info.plot;
    const ss=Object.keys(ep).sort((a,b)=>+a-+b);
    const sel=document.getElementById('epss');sel.innerHTML='';
    if(!ss.length){document.getElementById('eprl').innerHTML='<div class="stb"><p>SEM EPISÓDIOS</p></div>';return;}
    ss.forEach((s,i)=>{
      const b=document.createElement('button');b.className='sea'+(i===0?' on':'');b.textContent='T'+s;
      b.onclick=()=>{document.querySelectorAll('.sea').forEach(z=>z.classList.remove('on'));b.classList.add('on');renderEps(ep[s],item.name);};
      sel.appendChild(b);
    });
    renderEps(ep[ss[0]],item.name);
  }catch(e){document.getElementById('eprl').innerHTML=`<div class="stb"><p>${x(e.message)}</p></div>`;}
}

function renderEps(eps,sname){
  const el=document.getElementById('eprl');el.innerHTML='';
  if(!eps?.length){el.innerHTML='<div class="stb"><p>VAZIO</p></div>';return;}
  const f=document.createDocumentFragment();
  eps.forEach(ep=>{
    const url=`${sv}/series/${us}/${pw}/${ep.id}.${ep.container_extension||'mkv'}`;
    const d=document.createElement('div');
    d.className='epr'+(curl===url?' on':'');
    d.innerHTML=`<span class="epn">E${ep.episode_num}</span><span class="epnm">${x(ep.title||'Ep.'+ep.episode_num)}</span>${ep.info?.duration?`<span class="epd">${x(ep.info.duration)}</span>`:''}`;
    d.onclick=()=>{
      document.querySelectorAll('.epr').forEach(z=>z.classList.remove('on'));
      d.classList.add('on');curl=url;
      document.getElementById('cc-name').textContent=sname+' · E'+ep.episode_num;
      document.getElementById('cc-desc').textContent=ep.info?.plot||'';
      startPlay(url,sname+' E'+ep.episode_num,false,null);
    };
    f.appendChild(d);
  });
  el.appendChild(f);
}
function closeEp(){document.getElementById('epp').style.display='none';}

/* ─── FAVORITOS ─── */
function loadFavs(){
  const f=gF();
  streams=f;cats=[];vcats=[];
  activeCatIdx=-1;activeCatItems=f;activeCatName='⭐ FAVORITOS';
  document.getElementById('ca-list').innerHTML='<div class="stb"><p style="color:var(--td)">Seus favoritos abaixo</p></div>';
  document.getElementById('cb-title').textContent='⭐ FAVORITOS';
  document.getElementById('cb-msg').style.display='none';
  document.getElementById('cb-grid').style.display='';
  document.getElementById('cb-srch').value='';
  renderGrid(f);
  setMainState('s-items');
}

/* ─── LOGOUT ─── */
function sair(){localStorage.removeItem('tron_s');sessionStorage.removeItem('tron_s');if(HLS)HLS.destroy();location.href='index.html';}
function x(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

/* ─── TECLADO ─── */
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT')return;
  if(e.key===' '){const v=document.getElementById('vid');if(v.src){e.preventDefault();v.paused?v.play():v.pause();}}
  if(e.key==='f'||e.key==='F')goFull();
  if(e.key==='Escape'){if(playMode)exitPlayer();else closeEp();}
});
</script>
